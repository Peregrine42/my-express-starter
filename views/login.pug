extends ./layout

block stylesheets
  link(rel="stylesheet" href="/public/pages/login.css")

block content
  h1 Login
  if error
    p.login-error= error
  - var action = "/login" + (redirectTo ? "?redirect=" + encodeURIComponent(redirectTo) : "")
  form(action=action method="post")
    +csrfField
    label(for="username") Username
    input#username(type="text" name="username" required value=username)
    label(for="password") Password
    input#password(type="password" name="password" required)
    input(type="submit" value="Login")
