{
  "name": "my-app",
  "dependencies": {
    "argon2": "0.44.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "ioredis": "5.10.1",
    "lodash": "4.18.1",
    "method-override": "3.0.0",
    "p-map": "7.0.4",
    "pg": "8.20.0",
    "pug": "3.0.4",
    "umzug": "3.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@mariozechner/pi-coding-agent": "0.65.0",
    "@soleone/pi-tasks": "0.4.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/argon2": "0.14.1",
    "@types/axios": "0.14.4",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/lodash": "4.17.24",
    "@types/method-override": "3.0.0",
    "@types/node": "25.5.2",
    "@types/pg": "8.20.0",
    "@types/redis": "4.0.11",
    "@vitest/coverage-v8": "4.1.2",
    "axios": "1.14.0",
    "concurrently": "9.2.1",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "light-my-request": "6.6.0",
    "nodemon": "3.1.14",
    "npm-check-updates": "20.0.0",
    "patch-package": "8.0.1",
    "pi-brain": "0.1.7",
    "pi-plan-md": "0.1.7",
    "pkgroll": "2.27.0",
    "playwright": "1.59.1",
    "prettier": "3.8.1",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.2"
  },
  "overrides": {
    "yauzl": "3.2.1",
    "flatted": "3.4.2",
    "typescript": "6.0.2",
    "ajv": "8.18.0",
    "eslint": {
      "ajv": "6.14.0"
    },
    "lodash": "4.18.1"
  },
  "scripts": {
    "db:create": "node --env-file=.env --import tsx src/migrations/create.ts",
    "db:up": "node --env-file=.env --import tsx src/migrations/run.ts up",
    "db:down": "node --env-file=.env --import tsx src/migrations/run.ts down",
    "db:status": "node --env-file=.env --import tsx src/migrations/run.ts status",
    "frontend:install": "cd frontend/ && npm i -- ",
    "frontend:build": "cd frontend/ && npm run build",
    "frontend:start": "cd frontend/ && npm start",
    "frontend:dev": "nodemon --config ./nodemon.frontend.json -x npm run frontend:start",
    "frontend:test": "cd frontend/ && npm test -- --coverage",
    "frontend:test:watch": "nodemon --config ./nodemon.frontend.json -x npm run frontend:test -- -- ",
    "tsc": "tsc || exit 1",
    "lint": "prettier -w . && eslint",
    "backend:build": "npm run tsc && tsdown --config ./tsdown.config.mts && npm run lint",
    "backend:test": "npm run tsc && npm run lint && node --env-file=.env ./node_modules/vitest/vitest.mjs run --coverage",
    "backend:test:watch": "node --env-file=.env ./node_modules/vitest/vitest.mjs",
    "backend:build:start": "npm run backend:build && npm start",
    "backend:dev": "nodemon -x npm run backend:build:start -- -- ",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "node --enable-source-maps --env-file=.env dist/src/index.js",
    "dev": "concurrently npm:frontend:dev npm:backend:dev",
    "test": "npm run backend:test && npm run frontend:test && npm run test:e2e",
    "test:watch": "concurrently npm:backend:test:watch npm:frontend:test:watch",
    "test:e2e": "node --env-file=.env ./node_modules/vitest/vitest.mjs run --config vitest.config.e2e.ts",
    "postinstall": "patch-package"
  }
}
