{
  "name": "my-app",
  "type": "module",
  "dependencies": {
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "ioredis": "5.10.0",
    "lodash": "4.17.23",
    "pug": "3.0.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/axios": "0.14.4",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/jest": "30.0.0",
    "@types/jsdom": "28.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.0",
    "@types/redis": "4.0.11",
    "@types/supertest": "7.2.0",
    "axios": "1.13.6",
    "concurrently": "9.2.1",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "happy-dom": "20.8.4",
    "jest": "30.3.0",
    "jest-puppeteer": "11.0.0",
    "jsdom": "28.1.0",
    "light-my-request": "6.6.0",
    "nodemon": "3.1.14",
    "npm-check-updates": "19.6.3",
    "pkgroll": "2.27.0",
    "prettier": "3.8.1",
    "puppeteer": "24.39.1",
    "supertest": "7.2.2",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "overrides": {
    "yauzl": "3.2.1",
    "flatted": "3.4.0"
  },
  "scripts": {
    "frontend:install": "cd frontend/ && npm i -- ",
    "frontend:build": "cd frontend/ && npm run build",
    "frontend:start": "cd frontend/ && npm start",
    "frontend:dev": "nodemon --config ./nodemon.frontend.json -x npm run frontend:start",
    "frontend:test": "cd frontend/ && npm test",
    "frontend:test:watch": "nodemon --config ./nodemon.frontend.json -x npm run frontend:test -- -- ",
    "tsc": "tsc || exit 1",
    "lint": "prettier -w . && eslint",
    "backend:build": "npm run tsc && tsdown --config ./tsdown.config.mts && npm run lint",
    "backend:test:build": "npm run tsc && tsdown --config ./tsdown.test.config.mts && npm run lint",
    "backend:test": "npm run backend:test:build && node --disable-warning=ExperimentalWarning --experimental-vm-modules --env-file=.env ./node_modules/.bin/jest --selectProjects=main --config jest.config.mjs --no-cache",
    "backend:test:watch": "nodemon -x npm run backend:test -- -- ",
    "backend:build:start": "npm run backend:build && npm start",
    "backend:dev": "nodemon -x npm run backend:build:start -- -- ",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "node --env-file=.env dist/src/index.js",
    "dev": "concurrently npm:frontend:dev npm:backend:dev",
    "test": "npm run backend:test && npm run frontend:test && npm run test:e2e",
    "test:watch": "concurrently npm:backend:test:watch npm:frontend:test:watch",
    "test:e2e": "npm run backend:test:build && node --env-file=.env ./node_modules/.bin/jest --selectProjects=e2e --config jest.config.mjs --no-cache"
  }
}
